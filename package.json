{
  "name": "nestograms",
  "private": true,
  "version": "1.0.0",
  "description": "A highly polished, clean, and minimalistic nonogram puzzle Chrome Extension (Manifest V3)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"index.html\"",
    "generate-puzzles": "tsx scripts/generate-puzzles.ts",
    "seed-puzzles": "tsx scripts/seed-puzzles.ts"
  },
  "dependencies": {
    "firebase": "^10.12.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.1",
    "terser": "^5.48.0",
    "tsx": "^4.23.0",
    "typescript": "^5.4.5",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}

{
  "manifest_version": 3,
  "name": "Nestograms",
  "version": "1.0.0",
  "description": "A highly polished, clean, and minimalistic nonogram puzzle Chrome Extension",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Nestograms"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "offline_enabled": true
}
